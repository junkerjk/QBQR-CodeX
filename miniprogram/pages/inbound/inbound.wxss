.container {
  height: 100vh;
  background-color: #F8F9FA;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 借用码卡片 */
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.code-info .label {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.code-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9800;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.status-badge {
  background-color: #FFF3E0;
  color: #FF9800;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.user-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  border-top: 1rpx solid #F5F5F5;
  padding-top: 24rpx;
}

.detail-item .label {
  font-size: 20rpx;
  color: #CCC;
  display: block;
  margin-bottom: 4rpx;
}

.value-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.value-row .icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: #999;
}

/* 提示 */
.tips-box {
  background-color: #FFF9F2;
  border: 1rpx solid #FFE0B2;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.tips-text {
  font-size: 20rpx;
  color: #E67E22;
  margin-left: 12rpx;
  line-height: 1.5;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  margin-left: 10rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

/* 设备列表 */
.asset-item {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.asset-item.returned {
  opacity: 0.6;
  background-color: #F9F9F9;
}

.asset-main {
  display: flex;
  align-items: center;
}

.asset-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.asset-info {
  display: flex;
  flex-direction: column;
}

.asset-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.asset-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.return-time {
  font-size: 18rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.stepper-box {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stepper {
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.stepper-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #333;
  background-color: #EEEEEE;
}

.stepper-btn.disabled {
  color: #CCC;
}

.stepper-num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.toggle-label {
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
}

.toggle-label.active {
  color: #FF9800;
  font-weight: bold;
}

.returned-badge {
  display: flex;
  align-items: center;
  background-color: #E8F5E9;
  color: #4CAF50;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.returned-badge icon {
  margin-right: 4rpx;
}

/* 底部栏 */
.bottom-bar {
  background-color: #fff;
  padding: 20rpx 30rpx 60rpx;
  border-top: 1rpx solid #EEE;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-left {
  font-size: 24rpx;
  color: #999;
}

.summary-left .highlight {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9800;
}

.summary-right {
  font-size: 22rpx;
  color: #CCC;
}

.confirm-btn {
  background-color: #FF9800;
  color: #fff;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.2);
}

.confirm-btn .icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}
