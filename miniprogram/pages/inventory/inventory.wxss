.container {
  padding: 0;
  background-color: #F5F5F5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 无权限提示 */
.no-permission {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.no-permission .tips {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-top: 40rpx;
}

.no-permission .sub-tips {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 库管员面板 */
.admin-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-row {
  display: flex;
  align-items: center;
}

.title-row .icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.title-row .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.export-btn {
  background-color: #FF9800;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  margin: 0;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.export-btn .btn-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 待审批卡片 */
.approval-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  margin-bottom: 20rpx;
}

.history-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.pending-list {
  max-height: 320rpx;
}

.history-list {
  max-height: 520rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-count {
  font-size: 22rpx;
  color: #999;
}

.empty-box {
  text-align: center;
  padding: 60rpx 0;
  color: #CCC;
  font-size: 24rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F9F9F9;
}

.order-item.compact {
  padding: 16rpx 0;
}

.order-item.compact .user-avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 28rpx;
}

.order-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #FF9800;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  min-width: 0;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.dept-tag {
  font-size: 18rpx;
  color: #999;
  background-color: #F5F5F5;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.order-time {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.order-pkg {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.status-tag {
  font-size: 20rpx;
  color: #FF9800;
  background-color: #FFF3E0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #FFE0B2;
}

.status-tag.approved {
  color: #4CAF50;
  background-color: #E8F5E9;
  border-color: #C8E6C9;
}

.status-tag.active {
  color: #2196F3;
  background-color: #E3F2FD;
  border-color: #BBDEFB;
}

.status-tag.returned {
  color: #9E9E9E;
  background-color: #F5F5F5;
  border-color: #EEEEEE;
}

.status-tag.rejected {
  color: #F44336;
  background-color: #FFEBEE;
  border-color: #FFCDD2;
}

/* 底部扫码 */
.bottom-actions {
  margin-top: auto;
  display: flex;
  gap: 30rpx;
  padding-bottom: 40rpx;
}

.scan-btn {
  flex: 1;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  transition: transform 0.1s;
}

.scan-btn:active {
  transform: scale(0.96);
}

.scan-out {
  background-color: #F44336;
}

.scan-in {
  background-color: #4CAF50;
}

.icon-circle {
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.icon-circle .icon {
  font-size: 28rpx;
}

.btn-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 导出弹窗 */
.export-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
}

.export-dialog {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.export-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.export-section {
  margin-bottom: 20rpx;
}

.export-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.export-label.required::after {
  content: ' *';
  color: #F44336;
}

.date-range {
  display: flex;
  align-items: center;
}

.date-cell {
  min-width: 220rpx;
  padding: 12rpx 18rpx;
  border-radius: 12rpx;
  background: #F7F8FA;
  border: 1rpx solid #E8E8E8;
  font-size: 24rpx;
  color: #333;
}

.date-sep {
  margin: 0 12rpx;
  font-size: 22rpx;
  color: #999;
}

.check-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.check-grid.single-col {
  grid-template-columns: 1fr;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 10rpx;
  border-radius: 10rpx;
  background: #FAFAFA;
  font-size: 24rpx;
  color: #333;
}

.dept-scroll {
  max-height: 180rpx;
}

.dept-empty {
  font-size: 22rpx;
  color: #999;
  padding: 10rpx 0;
}

.email-input {
  border: 1rpx solid #E8E8E8;
  border-radius: 12rpx;
  background: #FAFAFA;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
}

.dialog-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 16rpx;
}

.dialog-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  line-height: 82rpx;
}

.dialog-btn.cancel {
  background: #F2F2F2;
  color: #666;
}

.dialog-btn.submit {
  background: #FF9800;
  color: #fff;
}
