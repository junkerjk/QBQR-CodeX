<view class="container">
  <view class="empty-tips" wx:if="{{list.length === 0}}">
    <icon type="info" size="64" color="#ccc"/>
    <text>您还没有预约记录</text>
    <button class="go-reserve" type="primary" bindtap="onGoReserve">立即预约</button>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="_id">
    <view class="card-header">
      <text class="item-name">{{item.itemName}}</text>
      <text class="status {{item.statusClass}}">{{item.statusText}}</text>
    </view>
    <view class="card-body">
      <view class="info-row"><text class="label">数量：</text><text class="value">{{item.count}}</text></view>
      <view class="info-row"><text class="label">日期：</text><text class="value">{{item.date}}</text></view>
    </view>
    <view class="card-footer" wx:if="{{item.status === 'approved'}}">
      <button class="qr-btn" size="mini" bindtap="onShowQR" data-id="{{item._id}}">查看取货码</button>
    </view>
  </view>

  <!-- 二维码弹窗模拟 -->
  <view class="qr-modal" wx:if="{{showQR}}" bindtap="onCloseQR">
    <view class="qr-content" catchtap="stop">
      <text class="qr-title">取货二维码</text>
      <view class="qr-placeholder">
        <icon type="success" size="100" color="#07C160"/>
      </view>
      <text class="qr-tips">请将此二维码展示给库管员扫码放行</text>
      <button class="close-btn" bindtap="onCloseQR">关闭</button>
    </view>
  </view>
</view>
